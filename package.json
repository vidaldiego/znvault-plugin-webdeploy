{
  "name": "@zincapp/znvault-plugin-webdeploy",
  "version": "0.2.0",
  "description": "Generic web-app deployment plugin for znvault CLI (rsync/PM2/nginx over SSH-CA)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./cli": { "types": "./dist/cli.d.ts", "import": "./dist/cli.js" }
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc --sourceMap false",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "prepublishOnly": "npm run build:prod"
  },
  "keywords": ["znvault", "deploy", "rsync", "pm2", "nginx", "ssh-ca"],
  "author": "ZincApp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vidaldiego/znvault-plugin-webdeploy.git"
  },
  "homepage": "https://github.com/vidaldiego/znvault-plugin-webdeploy#readme",
  "bugs": { "url": "https://github.com/vidaldiego/znvault-plugin-webdeploy/issues" },
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "@zincapp/znvault-cli": ">=2.11.0"
  },
  "peerDependenciesMeta": {
    "@zincapp/znvault-cli": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "commander": "^14.0.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "~4.0.17"
  },
  "engines": { "node": ">=18.0.0" }
}
